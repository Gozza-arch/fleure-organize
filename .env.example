# Port du serveur (Railway le définit automatiquement)
PORT=3001

# Chemin de la base de données SQLite
# En production sur Railway : /data/fleure.db
DB_PATH=./backend/data/fleure.db

# Répertoire de stockage des flyers uploadés
# En production sur Railway : /data/uploads
UPLOADS_DIR=./backend/uploads

# Environnement
NODE_ENV=development
