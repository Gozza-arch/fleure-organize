{
  "name": "fleure-organize",
  "version": "1.0.0",
  "description": "Gestionnaire d'événements DJ",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun --watch backend/server.js",
    "dev:frontend": "cd frontend && bun run dev",
    "install:all": "bun install && cd frontend && bun install",
    "build": "cd frontend && bun run build",
    "start": "bun backend/server.js"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "cloudinary": "^2.5.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1"
  }
}
